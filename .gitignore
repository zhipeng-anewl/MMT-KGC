# Large archive/dataset files (not tracked by Git LFS)
# Note: binary model files (*.pth, *.pt, *.bin, *.h5, *.pkl, *.npz) are
# tracked via Git LFS — see .gitattributes — so they are NOT listed here.
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.7z

# Large text/CSV datasets
data/*.txt
data/*.csv
data/*.tsv
data/*.json
datasets/

# Model checkpoints and outputs
checkpoints/
outputs/
logs/
runs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
venv/
env/
.env/
.venv/

# Jupyter
.ipynb_checkpoints/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
